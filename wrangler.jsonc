{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memoupdater",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  // ---------------------------------------------------------------
  // Phase 4A: LLM follow-up memo generation. DEFAULT OFF for safety.
  //
  // To enable, set ALL of the following:
  //   1. LLM_ENABLED = "true"     (in this file's "vars" block)
  //   2. LLM_PROVIDER = "anthropic"
  //   3. LLM_MODEL    = "claude-sonnet-4-6"  (or another supported id)
  //   4. LLM_API_KEY  = <set as a secret, never committed>:
  //        wrangler secret put LLM_API_KEY
  //
  // WARNING: this Worker has no auth or rate limiting. Enabling LLM
  // generation on a public unauthenticated Worker can incur provider
  // costs from arbitrary visitors. Protect with Cloudflare Access,
  // WAF rules, or another access-control layer before flipping
  // LLM_ENABLED to "true" in production.
  //
  // If LLM_ENABLED is not "true" OR any of provider/model/key is
  // missing, /api/llm/status returns {configured:false} and the
  // client silently falls back to the deterministic v0 generator.
  // ---------------------------------------------------------------
  "vars": {
    "LLM_ENABLED": "false",
    "LLM_PROVIDER": "anthropic",
    "LLM_MODEL": "claude-sonnet-4-6"
  }

  // ---------------------------------------------------------------
  // Phase 2+ placeholders. Uncomment, then run `npm run cf-typegen`.
  // ---------------------------------------------------------------
  //
  // "vars": {
  //   "ENVIRONMENT": "production"
  // },
  //
  // R2: store uploaded memos, financial PDFs, transcripts
  // "r2_buckets": [
  //   { "binding": "MEMO_UPLOADS", "bucket_name": "memo-updater-uploads" }
  // ],
  //
  // D1: persist projects, MemoDNA extractions, generation runs
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "memo-updater-db",
  //     "database_id": "REPLACE_ME"
  //   }
  // ],
  //
  // Queues: async LLM extraction / generation pipeline
  // "queues": {
  //   "producers": [
  //     { "binding": "MEMO_QUEUE", "queue": "memo-jobs" }
  //   ],
  //   "consumers": [
  //     { "queue": "memo-jobs", "max_batch_size": 1 }
  //   ]
  // },
  //
  // Workflows: durable multi-step memo generation
  // "workflows": [
  //   {
  //     "binding": "MEMO_WORKFLOW",
  //     "name": "memo-workflow",
  //     "class_name": "MemoWorkflow"
  //   }
  // ]
  //
  // Secrets (set with `wrangler secret put`, never committed):
  //   ANTHROPIC_API_KEY
  //   OPENAI_API_KEY
}
