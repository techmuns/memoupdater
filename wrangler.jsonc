{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memoupdater",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  // ---------------------------------------------------------------
  // Phase 4A/4B: LLM follow-up memo generation. DEFAULT OFF for safety.
  //
  // To enable, set ALL of the following (server-side only):
  //   1. LLM_ENABLED       = "true"     (in this "vars" block)
  //   2. LLM_PROVIDER      = "anthropic"
  //   3. LLM_MODEL         = "claude-sonnet-4-6" (or another supported id)
  //   4. LLM_API_KEY       = <secret, never committed>:
  //        wrangler secret put LLM_API_KEY
  //
  // Phase 4B app-level access gate (DEFAULT ON):
  //   5. LLM_GATE_ENABLED  = "true"     (in this "vars" block)
  //   6. LLM_GATE_SECRET   = <secret, never committed>:
  //        wrangler secret put LLM_GATE_SECRET
  //
  // The gate requires callers to send X-Memo-LLM-Gate: <secret>. The
  // Worker compares with constant-time equality. Without a valid token
  // /api/generate/follow-up-memo returns {ok:false, code:
  // "llm_access_denied"} and the client falls back to the deterministic
  // v0 generator. The gate short-circuits before any Anthropic call, so
  // rejected requests cost nothing on the provider side.
  //
  // WARNING: this Worker has NO auth and NO rate limiting. The gate is
  // a single shared secret, not user auth. Enabling LLM_ENABLED=true
  // WITH LLM_GATE_ENABLED=false on a public Worker can incur provider
  // costs from arbitrary visitors. Always protect with Cloudflare
  // Access, WAF, rate limiting, or another access-control layer before
  // public deployment. The gate alone is not a substitute.
  //
  // If LLM_ENABLED !== "true", or if any required field is missing,
  // /api/llm/status reports llmReady:false and the client silently
  // falls back to the deterministic v0 generator.
  // ---------------------------------------------------------------
  "vars": {
    "LLM_ENABLED": "false",
    "LLM_PROVIDER": "anthropic",
    "LLM_MODEL": "claude-sonnet-4-6",
    "LLM_GATE_ENABLED": "true"
  }

  // ---------------------------------------------------------------
  // Phase 2+ placeholders. Uncomment, then run `npm run cf-typegen`.
  // ---------------------------------------------------------------
  //
  // "vars": {
  //   "ENVIRONMENT": "production"
  // },
  //
  // R2: store uploaded memos, financial PDFs, transcripts
  // "r2_buckets": [
  //   { "binding": "MEMO_UPLOADS", "bucket_name": "memo-updater-uploads" }
  // ],
  //
  // D1: persist projects, MemoDNA extractions, generation runs
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "memo-updater-db",
  //     "database_id": "REPLACE_ME"
  //   }
  // ],
  //
  // Queues: async LLM extraction / generation pipeline
  // "queues": {
  //   "producers": [
  //     { "binding": "MEMO_QUEUE", "queue": "memo-jobs" }
  //   ],
  //   "consumers": [
  //     { "queue": "memo-jobs", "max_batch_size": 1 }
  //   ]
  // },
  //
  // Workflows: durable multi-step memo generation
  // "workflows": [
  //   {
  //     "binding": "MEMO_WORKFLOW",
  //     "name": "memo-workflow",
  //     "class_name": "MemoWorkflow"
  //   }
  // ]
  //
  // Secrets (set with `wrangler secret put`, never committed):
  //   ANTHROPIC_API_KEY
  //   OPENAI_API_KEY
}
